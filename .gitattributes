# Normalise all text files to LF in the repo, CRLF on Windows checkout
* text=auto eol=lf

# Explicitly LF for source files
*.py   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.sh   text eol=lf
*.json text eol=lf
*.csv  text eol=lf
*.env  text eol=lf

# Shell scripts must always be LF (Linux/Pi deployment)
*.sh   text eol=lf

# Binary files — no conversion
*.db     binary
*.png    binary
*.jpg    binary
*.ico    binary
*.woff2  binary
